{
  "name": "staked-media-extension",
  "private": true,
  "version": "0.1.0",
  "description": "Build tooling for Staked Media Copilot browser extension",
  "scripts": {
    "clean": "rm -rf dist",
    "build:scripts": "node scripts/build-scripts.mjs",
    "build:styles": "tailwindcss -c tailwind.config.cjs -i src/styles/panel.tailwind.css -o dist/panel.css --minify",
    "copy:static": "cp public/manifest.json public/panel.html public/options.html dist/",
    "build": "npm run clean && npm run build:scripts && npm run build:styles && npm run copy:static",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
