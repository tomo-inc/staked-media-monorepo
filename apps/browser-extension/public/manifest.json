{
  "manifest_version": 3,
  "name": "Staked Media Copilot",
  "description": "MVP browser extension for generating X/Twitter drafts through the existing Python backend.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.sayviner.top:8443/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.sayviner.top:8443 http://127.0.0.1:* http://localhost:*"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Staked Media Copilot",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
