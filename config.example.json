{
  "app_env": "development",
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "reload": false
  },
  "database": {
    "url": "postgresql://postgres:postgres@localhost:5432/staked_media"
  },
  "twitter": {
    "data_url": "http://52.76.50.165:8081",
    "data_proxy": "",
    "max_ingest_tweets": 100,
    "persona_sample_size": 40
  },
  "llm": {
    "provider": "openai",
    "http_proxy": "",
    "max_retries": 2,
    "retry_backoff_seconds": 1.0,
    "score_timeout_seconds": 20,
    "request_timeout_seconds": 30,
    "openai": {
      "api_key": "",
      "model": "gpt-4.1-mini",
      "base_url": "https://api.openai.com/v1"
    },
    "gemini": {
      "api_key": "",
      "model": "gemini-2.0-flash",
      "base_url": "https://generativelanguage.googleapis.com/v1beta"
    }
  },
  "log": {
    "level": "INFO",
    "file_path": "data/app.log",
    "max_body_chars": 500,
    "enable_file": true
  },
  "content": {
    "similarity_threshold": 0.92,
    "rewrite_max_rounds": 3,
    "max_generation_attempts": 3,
    "evaluation_max_workers": 4,
    "variant_max_workers": 3
  },
  "web_enrichment": {
    "enabled": true,
    "timeout_seconds": 8.0,
    "max_items": 12,
    "recency_hours": 24
  },
  "hot_events": {
    "provider_6551_token": "",
    "auto_refresh_interval_seconds": 300,
    "min_refresh_cooldown_seconds": 60,
    "pre_translate_languages": [
      "zh-CN",
      "en"
    ],
    "fusion": {
      "source_weight_news": 1.0,
      "source_weight_tweet": 1.0,
      "tweet_weight_retweet": 1.5,
      "tweet_weight_like": 1.0,
      "tweet_weight_reply": 2.0,
      "tweet_weight_quote": 2.5,
      "tweet_follower_cap_k": 50.0,
      "time_decay_half_life_hours": 12.0,
      "max_heat_score": 100.0
    }
  }
}
